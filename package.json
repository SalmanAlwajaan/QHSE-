{
  "name": "sentinel-qhse",
  "private": true,
  "version": "1.0.0",
  "description": "Sentinel — QHSE Operations Platform for an electrical contractor (local, offline, owned)",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5273 && electron .",
    "dev": "concurrently -k -n VITE,APP -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "build": "vite build",
    "start": "electron .",
    "preview": "vite preview"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "i18next": "^26.3.6",
    "lucide-react": "^0.456.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.10",
    "recharts": "^2.13.3",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
